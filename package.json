{
  "name": "@ajxdevx/motion-blocks",
  "version": "1.0.0",
  "description": "Animated React components for modern websites.",
  "author": "Anass Jid",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ajxdevx/motion-blocks"
  },
  "bugs": {
    "url": "https://github.com/ajxdevx/motion-blocks/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs"
      }
    },
    "./styles.css": "./dist/style.css"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsup && npm run build:css",
    "build:css": "tailwindcss -i ./src/styles/index.css -o ./dist/style.css --minify",
    "lint": "eslint src demo",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "prepublishOnly": "npm run build",
    "publish:npm": "npm publish --access public"
  },
  "peerDependencies": {
    "framer-motion": "^11.0.0 || ^12.0.0",
    "gsap": "^3.12.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "gsap": {
      "optional": true
    }
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "tailwind-merge": "^2.6.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "framer-motion": "^11.15.0",
    "globals": "^15.14.0",
    "gsap": "^3.12.5",
    "postcss": "^8.4.49",
    "prettier": "^3.4.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.17",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.2",
    "vite": "^6.0.5"
  },
  "keywords": [
    "motion-blocks",
    "motionblocks",
    "react",
    "motion",
    "animation",
    "framer-motion",
    "gsap",
    "ui",
    "components",
    "blocks",
    "tailwind",
    "nextjs"
  ],
  "publishConfig": {
    "access": "public"
  }
}
